# Copy to .env and fill in. Never commit .env.

# --- Database ---
DB_PATH=./data/finance.sqlite

# --- Telegram bot (daily summaries + reminders) ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# --- App ---
APP_TIMEZONE=Asia/Kolkata
DAILY_SUMMARY_TIME=21:00

# Statements are parsed locally from CSV, so no API key is needed, and the PDF
# password vault is gone, so no at-rest encryption key is either. If you are
# upgrading from the AI/PDF version, delete ANTHROPIC_API_KEY, ANTHROPIC_MODEL
# and APP_ENCRYPTION_KEY from your .env.
