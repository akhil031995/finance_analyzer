# --- Secrets ---
.env
.env.*
!.env.example

# --- Dependencies (restored via bin/deps.sh; composer.json + composer.lock are tracked) ---
/vendor/
/node_modules/

# --- The live database and every snapshot of it (paise-accurate personal data) ---
/data/
*.sqlite
*.sqlite-*
*.sqlite.bak

# A `php -S` dev server chdirs to the docroot and can create an empty DB here.
/public/data/

# --- Uploaded and source statements: your real financial data, never commit ---
/storage/uploads/*
!/storage/uploads/.gitkeep
/bank_statements/

# --- Editor / tooling local state ---
.claude/settings.local.json
.vscode/
.idea/
*.swp
*~

# --- OS cruft ---
.DS_Store
Thumbs.db

# --- Stray runtime output ---
*.log
nohup.out
